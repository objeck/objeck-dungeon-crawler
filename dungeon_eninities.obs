#~
Dungeon Lord - Boss Monster
~#
class DungeonLord from Monster {
	New(level : Int) {
		Parent(EntityType->GHOST,	# type (reuses Ghost sprites)
			level,					# level
			Int->Random(50, 60),	# max hp
			Int->Random(16, 18),	# strength
			Int->Random(10, 12),	# agility
			Int->Random(12, 14));	# stamina

		SetWeaponHit(48.0);
		SetArmorBlock(22.0);
	}

	method : public : GetName() ~ String {
		return "Dungeon Lord";
	}

	method : public : GetWinExp() ~ Int {
		return 100;
	}

	method : public : GetImageStart() ~ Int {
		return 8;
	}

	method : public : IsBoss() ~ Bool {
		return true;
	}
}
